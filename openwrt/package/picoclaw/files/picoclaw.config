config picoclaw 'picoclaw'
	# Set to 1 to enable the service
	option enabled '0'

	# LLM provider: anthropic, openai, deepseek, longcat, openai_compat
	option provider 'anthropic'

	# Model name (short alias used internally)
	# Anthropic:  claude-sonnet-4.6 | claude-opus-4-6 | claude-haiku-4-5
	# OpenAI:     gpt-4o | gpt-4o-mini | gpt-5.4
	# DeepSeek:   deepseek-chat | deepseek-reasoner
	# LongCat:    LongCat-Flash-Thinking
	option model 'claude-sonnet-4.6'

	# API key for the selected provider
	option api_key ''

	# Optional: custom API base URL (leave empty to use provider default)
	# Required for openai_compat providers or self-hosted deployments
	option api_base ''

	# Gateway bind address — '0.0.0.0' listens on all interfaces (external access)
	option gateway_host '0.0.0.0'

	# Gateway listen port
	option gateway_port '18790'

	# Log level: debug | info | warn | error
	option log_level 'info'

	# Directory for workspace, memory, and database files
	option data_dir '/var/lib/picoclaw'
