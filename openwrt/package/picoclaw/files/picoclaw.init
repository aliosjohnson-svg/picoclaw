#!/bin/sh /etc/rc.common
# PicoClaw AI Agent - procd init script
# SPDX-License-Identifier: MIT

USE_PROCD=1
START=90
STOP=10

PROG=/usr/bin/picoclaw
DATA_DIR=/var/lib/picoclaw
CONFIG_FILE=/etc/picoclaw/config.json

# Generate a minimal but complete picoclaw config.json from UCI settings
generate_config() {
	local cfg="$1"
	local data_dir

	config_get data_dir    "$cfg" data_dir    "$DATA_DIR"
	config_get provider    "$cfg" provider    "anthropic"
	config_get model       "$cfg" model       "claude-sonnet-4.6"
	config_get api_key     "$cfg" api_key     ""
	config_get api_base    "$cfg" api_base    ""
	config_get gateway_host "$cfg" gateway_host "0.0.0.0"
	config_get gateway_port "$cfg" gateway_port "18790"
	config_get log_level   "$cfg" log_level   "info"

	# Build the full model identifier: provider/model
	local full_model="${provider}/${model}"

	# Determine api_base default per provider
	if [ -z "$api_base" ]; then
		case "$provider" in
			anthropic)         api_base="https://api.anthropic.com/v1" ;;
			openai)            api_base="https://api.openai.com/v1" ;;
			deepseek)          api_base="https://api.deepseek.com/v1" ;;
			longcat)           api_base="https://api.longcat.ai/v1" ;;
			*)                 api_base="" ;;
		esac
	fi

	mkdir -p "${data_dir}/workspace" /etc/picoclaw

	# Write config.json using shell printf (no jq dependency)
	{
		printf '{\n'
		printf '  "version": 1,\n'
		printf '  "agents": {\n'
		printf '    "defaults": {\n'
		printf '      "workspace": "%s/workspace",\n' "$data_dir"
		printf '      "restrict_to_workspace": false,\n'
		printf '      "model_name": "%s"\n' "$model"
		printf '    }\n'
		printf '  },\n'
		printf '  "model_list": [\n'
		printf '    {\n'
		printf '      "model_name": "%s",\n' "$model"
		printf '      "model": "%s",\n' "$full_model"
		printf '      "api_key": "%s"' "$api_key"
		if [ -n "$api_base" ]; then
			printf ',\n      "api_base": "%s"\n' "$api_base"
		else
			printf '\n'
		fi
		printf '    }\n'
		printf '  ],\n'
		printf '  "gateway": {\n'
		printf '    "host": "%s",\n' "$gateway_host"
		printf '    "port": %s,\n' "$gateway_port"
		printf '    "log_level": "%s"\n' "$log_level"
		printf '  }\n'
		printf '}\n'
	} > "$CONFIG_FILE"
}

start_instance() {
	local cfg="$1"
	local enabled data_dir gateway_host gateway_port log_level

	config_get_bool enabled "$cfg" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get data_dir     "$cfg" data_dir     "$DATA_DIR"
	config_get gateway_host "$cfg" gateway_host "0.0.0.0"
	config_get gateway_port "$cfg" gateway_port "18790"
	config_get log_level    "$cfg" log_level    "info"

	generate_config "$cfg"

	procd_open_instance
	procd_set_param command "$PROG" gateway
	procd_set_param env \
		PICOCLAW_HOME="$data_dir" \
		PICOCLAW_CONFIG="$CONFIG_FILE" \
		PICOCLAW_GATEWAY_HOST="$gateway_host" \
		PICOCLAW_GATEWAY_PORT="$gateway_port" \
		PICOCLAW_LOG_LEVEL="$log_level" \
		HOME="$data_dir"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile /var/run/picoclaw.pid
	procd_close_instance
}

start_service() {
	config_load picoclaw
	config_foreach start_instance picoclaw
}

service_triggers() {
	procd_add_reload_trigger picoclaw
}

reload_service() {
	stop
	start
}
